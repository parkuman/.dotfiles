# Jira API Configuration
# Copy this to your shell rc file (~/.zshrc, ~/.bashrc, etc.)

# Your Jira account email
export JIRA_USER="your-email@circleci.com"

# Generate an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
export JIRA_TOKEN="your-api-token-here"

# Your Jira instance domain (without https://)
export JIRA_DOMAIN="circleci.atlassian.net"
